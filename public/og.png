<style>
@import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Instrument+Serif:ital@0;1&display=swap');
.og-btn{font-family:Inter,sans-serif;font-weight:500;font-size:14px;padding:10px 18px;border-radius:var(--border-radius-md);cursor:pointer;border:0.5px solid var(--color-border-secondary);background:var(--color-background-primary);color:var(--color-text-primary)}
.og-btn:hover{background:var(--color-background-secondary)}
.og-btn:disabled{opacity:.5;cursor:wait}
.og-tab{font-family:Inter,sans-serif;font-size:13px;padding:6px 14px;border-radius:var(--border-radius-md);cursor:pointer;border:0.5px solid var(--color-border-tertiary);background:transparent;color:var(--color-text-secondary)}
.og-tab.active{background:var(--color-background-secondary);color:var(--color-text-primary);border-color:var(--color-border-secondary)}
</style>

<div style="padding:1rem 0">
<h2 class="sr-only">OG image preview para MUNConnect, 1200 por 630 pixels.</h2>

<div style="display:flex;gap:6px;margin-bottom:12px">
  <button class="og-tab active" id="tab-en" onclick="setLang('en')">English</button>
  <button class="og-tab" id="tab-pt" onclick="setLang('pt')">Português</button>
</div>

<div id="og-wrapper" style="width:100%;max-width:600px;height:315px;overflow:hidden;border-radius:var(--border-radius-lg);border:0.5px solid var(--color-border-tertiary)">
  <div id="og-capture" style="width:1200px;height:630px;transform:scale(0.5);transform-origin:top left;background:#0d1019;position:relative;overflow:hidden;font-family:Inter,sans-serif">

    <div style="position:absolute;top:-300px;left:50%;margin-left:-700px;width:1400px;height:800px;background:radial-gradient(ellipse 50% 50% at 50% 50%,rgba(139,92,246,.38) 0%,rgba(99,102,241,.14) 40%,transparent 70%);pointer-events:none"></div>
    <div style="position:absolute;bottom:-250px;left:-250px;width:800px;height:600px;background:radial-gradient(ellipse 50% 50% at 50% 50%,rgba(139,92,246,.16) 0%,transparent 70%);pointer-events:none"></div>

    <div style="position:absolute;top:70px;left:90px;display:flex;align-items:center;gap:14px">
      <div style="width:12px;height:12px;border-radius:50%;background:#f59e0b;flex-shrink:0"></div>
      <span style="font-size:22px;font-weight:600;letter-spacing:.2em;color:#b0b8c8;text-transform:uppercase;font-family:Inter,sans-serif">MUNCONNECT</span>
    </div>

    <div style="position:absolute;top:50%;left:90px;right:90px;transform:translateY(-50%)">
      <div id="og-title" style="font-family:'Instrument Serif',Georgia,serif;font-size:128px;line-height:1;font-weight:400;margin:0 0 32px;letter-spacing:-.02em;color:#f0f2f7">
        AI for <em style="font-style:italic;color:#a78bfa">Model UN</em>
      </div>
      <p id="og-sub" style="font-size:30px;line-height:1.45;color:#b0b8c8;max-width:920px;margin:0;font-weight:400;font-family:Inter,sans-serif">Motion generator, debate simulator, and conference calendar — all in one place.</p>
    </div>

    <div style="position:absolute;bottom:70px;left:90px;right:90px;display:flex;justify-content:space-between;align-items:center">
      <div style="width:80px;height:2px;background:linear-gradient(90deg,#f59e0b,transparent)"></div>
      <span style="font-size:18px;color:#b0b8c8;letter-spacing:.05em;font-weight:500;font-family:Inter,sans-serif">munconnect-two.vercel.app</span>
    </div>
  </div>
</div>

<div style="display:flex;gap:12px;align-items:center;margin-top:16px">
  <button id="dl-btn" class="og-btn" onclick="downloadOG()">↓ Baixar og.png (1200×630)</button>
  <span id="dl-status" style="font-family:Inter,sans-serif;font-size:13px;color:var(--color-text-secondary)"></span>
</div>
</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js"></script>
<script>
const COPY={
  en:{title:'AI for <em style="font-style:italic;color:#a78bfa">Model UN</em>',sub:'Motion generator, debate simulator, and conference calendar — all in one place.'},
  pt:{title:'IA para <em style="font-style:italic;color:#a78bfa">Model UN</em>',sub:'Gerador de moções, simulador de debate e calendário de conferências — tudo em um só lugar.'}
};
function setLang(lang){
  document.getElementById('og-title').innerHTML=COPY[lang].title;
  document.getElementById('og-sub').textContent=COPY[lang].sub;
  document.getElementById('tab-en').classList.toggle('active',lang==='en');
  document.getElementById('tab-pt').classList.toggle('active',lang==='pt');
}
async function downloadOG(){
  const btn=document.getElementById('dl-btn');
  const status=document.getElementById('dl-status');
  const wrapper=document.getElementById('og-wrapper');
  const capture=document.getElementById('og-capture');
  btn.disabled=true;
  status.textContent='Renderizando... (não feche)';
  try{
    if(document.fonts&&document.fonts.ready)await document.fonts.ready;
    wrapper.style.overflow='visible';
    wrapper.style.height='630px';
    capture.style.transform='none';
    await new Promise(r=>requestAnimationFrame(r));
    await new Promise(r=>setTimeout(r,600));
    const canvas=await html2canvas(capture,{
      width:1200,height:630,scale:1,
      backgroundColor:'#0d1019',
      logging:false,
      useCORS:true,
      allowTaint:true,
      windowWidth:1200,
      windowHeight:630
    });
    capture.style.transform='scale(0.5)';
    wrapper.style.overflow='hidden';
    wrapper.style.height='315px';
    const link=document.createElement('a');
    link.download='og.png';
    link.href=canvas.toDataURL('image/png');
    link.click();
    status.textContent='✓ Baixado!';
    setTimeout(()=>{status.textContent=''},4000);
  }catch(err){
    capture.style.transform='scale(0.5)';
    wrapper.style.overflow='hidden';
    wrapper.style.height='315px';
    status.textContent='✗ Erro: '+err.message;
    console.error(err);
  }finally{
    btn.disabled=false;
  }
}
</script>