rules_version = '2';

// ─────────────────────────────────────────────────────────────────────────────
// Firestore Security Rules — MUNConnect
//
// Hierarquia (ver src/data/firestore.js):
//   conferences/{conferenceId}
//     committees/{committeeId}
//       topics/{topicId}
//         subitems/{subitemId}    { status, ... }
//       documents/{docId}
//       members/{uid}             { role: "director" | "delegate", nome, pais, rfidUid }
//       attendance/{autoId}       { memberId, nome, pais, timestamp, status }
//   devices/{deviceId}            { pendingPairing }                             (raiz)
//   rfidTags/{rfidUid}            { conferenceId, committeeId, memberId, pairedAt } (raiz)
//
// Credenciamento RFID: os 3 totens são fixos e genéricos (qualquer delegado de
// qualquer comitê usa qualquer totem). rfidTags é a fonte da verdade global
// "qual delegado é esta tag"; devices só identifica o aparelho físico durante o
// pareamento.
//
// Princípios:
//   • Leitura liberada para qualquer usuário autenticado em toda a árvore.
//   • members quase imutável pelo client: só o diretor pode gravar rfidUid
//     (pareamento de crachá); nome/pais/role continuam só console / Admin SDK.
//   • Membros do comitê podem criar documents.
//   • Só directors podem alterar o status de subitems.
//   • attendance e devices são escritos SOMENTE pela Cloud Function de check-in
//     (Admin SDK, que ignora estas rules). O diretor só LÊ (painel de presença
//     e a pendência de pareamento do totem selecionado).
//   • rfidTags: o diretor cria/reatribui a tag do PRÓPRIO comitê pelo painel;
//     reatribuir uma tag de outro comitê exige ser diretor dos dois (dono antigo
//     e novo). Leitura fechada ao client (só a Cloud Function lê, via Admin SDK).
//   • Default deny para qualquer escrita não coberta explicitamente.
// ─────────────────────────────────────────────────────────────────────────────

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Admins ─────────────────────────────────────────────────────────────────
    // Leitura autenticada (AuthContext consulta admins/{email} no login).
    // Escrita só manual (console / Admin SDK).
    match /admins/{email} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // ── Helpers ──────────────────────────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }

    // Admin = existe doc em admins/{email} (mesma checagem do AuthContext).
    function isAdmin() {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/admins/$(request.auth.token.email));
    }

    // Existe doc em members/{uid} → usuário é membro do comitê.
    function isMember(conferenceId, committeeId) {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/conferences/$(conferenceId)/committees/$(committeeId)/members/$(request.auth.uid));
    }

    // Papel do usuário no comitê (null se não for membro).
    function memberRole(conferenceId, committeeId) {
      return get(/databases/$(database)/documents/conferences/$(conferenceId)/committees/$(committeeId)/members/$(request.auth.uid)).data.role;
    }

    function isDirector(conferenceId, committeeId) {
      return isMember(conferenceId, committeeId) &&
        memberRole(conferenceId, committeeId) == 'director';
    }

    // Somente o campo `status` mudou (nenhum outro campo foi afetado).
    function onlyStatusChanged() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status']);
    }

    // Somente o campo `rfidUid` mudou — pareamento de crachá pelo diretor.
    function onlyRfidUidChanged() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(['rfidUid']);
    }

    // ── Conferences ──────────────────────────────────────────────────────────
    match /conferences/{conferenceId} {
      allow read: if isSignedIn();
      allow write: if false;

      // ── Committees ─────────────────────────────────────────────────────────
      // Admins criam/editam comitês (inclui arquivar via campo status) e podem
      // excluir (delete em cascata parte do client — ver deleteCommittee).
      match /committees/{committeeId} {
        allow read: if isSignedIn();
        allow create, update, delete: if isAdmin();

        // ── Members ──────────────────────────────────────────────────────────
        // Leitura livre; create só manual (console/Admin SDK). Update só do
        // diretor e SÓ no campo rfidUid (pareamento de crachá) — nome/pais/role
        // seguem imutáveis pelo client. Admin pode deletar (cascata).
        match /members/{uid} {
          allow read: if isSignedIn();
          allow create: if false;
          allow update: if isDirector(conferenceId, committeeId) && onlyRfidUidChanged();
          allow delete: if isAdmin();
        }

        // ── Attendance (presença) ────────────────────────────────────────────
        // Registros de check-in do totem: escritos SÓ pela Cloud Function (Admin
        // SDK). Client nunca escreve; só o diretor lê (painel de presença).
        match /attendance/{attId} {
          allow read: if isDirector(conferenceId, committeeId);
          allow write: if false;
        }

        // ── Documents ────────────────────────────────────────────────────────
        // Qualquer membro do comitê pode criar. Sem update client-side.
        // Admin pode deletar (cascata ao excluir o comitê).
        match /documents/{docId} {
          allow read: if isSignedIn();
          allow create: if isMember(conferenceId, committeeId);
          allow update: if false;
          allow delete: if isAdmin();
        }

        // ── Topics ───────────────────────────────────────────────────────────
        // Admins criam/editam/excluem tópicos (tópicos iniciais e novos).
        match /topics/{topicId} {
          allow read: if isSignedIn();
          allow create, update, delete: if isAdmin();

          // ── Subitems ───────────────────────────────────────────────────────
          // Directors alteram o status (e nada além). Admins criam (subtópicos)
          // e deletam (cascata).
          match /subitems/{subitemId} {
            allow read: if isSignedIn();
            allow create, delete: if isAdmin();
            allow update: if isAdmin() ||
                             (isDirector(conferenceId, committeeId) && onlyStatusChanged());
          }
        }
      }
    }

    // ── Devices (totens de credenciamento) ──────────────────────────────────────
    // Coleção raiz. Totens genéricos (sem dono): o doc só guarda pendingPairing,
    // a pendência de pareamento gravada pelo ESP32 via Cloud Function. Como
    // qualquer diretor pode usar qualquer totem e o doc não carrega comitê, a
    // leitura fica liberada a qualquer autenticado (o payload é só um UID de tag,
    // baixa sensibilidade; a tela de pareamento é gated por isDirector na UI).
    // Escrita é SÓ da Cloud Function (Admin SDK ignora estas rules).
    match /devices/{deviceId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    // ── rfidTags (fonte da verdade global tag → delegado) ────────────────────────
    // Coleção raiz. O diretor cria a tag do próprio comitê pelo painel; reatribuir
    // uma tag existente exige ser diretor tanto do comitê NOVO (request) quanto do
    // ATUAL dono (resource) — impede roubo de tag entre comitês. delete e leitura
    // fechados ao client; só a Cloud Function lê (Admin SDK) para rotear check-ins.
    match /rfidTags/{rfidUid} {
      allow read: if false;
      allow create: if isDirector(request.resource.data.conferenceId,
                                  request.resource.data.committeeId);
      allow update: if isDirector(request.resource.data.conferenceId,
                                  request.resource.data.committeeId) &&
                       isDirector(resource.data.conferenceId,
                                  resource.data.committeeId);
      allow delete: if false;
    }

    // ── Default deny ───────────────────────────────────────────────────────────
    // Qualquer caminho não coberto acima: sem leitura e sem escrita.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
