# Copy to .env.local (gitignored) and fill in.

# ── Firebase (frontend) ───────────────────────────────────────────────────────
# Firebase Console → Configurações do projeto → Seus aplicativos → app Web.
# Vite só expõe variáveis com prefixo VITE_. Estes valores vão para o bundle do
# frontend (não são secretos); o que protege os dados são as Security Rules.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# ── Anthropic (serverless) ────────────────────────────────────────────────────
# Used only by the Vercel serverless function in /api/debate.js.
# This key MUST NEVER appear in the frontend bundle.
ANTHROPIC_API_KEY=

# ── Credenciamento RFID / totem (serverless) ──────────────────────────────────
# Usados só pela Vercel serverless function em /api/checkin.js. NUNCA no bundle
# do frontend nem no repo — configure em Vercel → Project → Settings → Env Vars.
#
# CHECKIN_SECRET: segredo compartilhado com o firmware do ESP32. O totem envia
# esse valor em cada POST; o endpoint recusa (401) se não bater. Gere um valor
# longo e aleatório e grave o mesmo no firmware.
CHECKIN_SECRET=
#
# FIREBASE_SERVICE_ACCOUNT: conta de serviço do Firebase (Console → Configurações
# do projeto → Contas de serviço → "Gerar nova chave privada") em BASE64 — evita
# problemas com os \n do private_key em painéis/CI. Gere o valor com:
#   base64 -w0 serviceAccountKey.json      (macOS: base64 -i serviceAccountKey.json)
# e cole a string resultante aqui. Dá ao endpoint acesso Admin (ignora as Security
# Rules) para gravar presença/pareamento.
FIREBASE_SERVICE_ACCOUNT=
